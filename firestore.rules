rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'vinothfreelancer2017@gmail.com';
    }

    // Users collection
    match /users/{docId} {
      // Anyone can register
      allow create: if true;

      // Only the owner of the document or an admin can read their specific profile details
      allow get: if request.auth != null && (request.auth.uid == docId || isAdmin());

      // Only admins or single-match validation queries (limit=1) can query lists
      allow list: if isAdmin() || request.query.limit == 1;

      // Only admin can update status/data, or delete users
      allow update, delete: if isAdmin();
    }

    // Counters collection (for registration ID sequencing)
    match /counters/{counterId} {
      allow read, write: if true;
    }
  }
}
